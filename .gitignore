# PlatformIO Build Artifacts
.pio/
.pioenvs/
.piolibdeps/
build/
build-*/
*.pyc

# Secrets — never commit credentials
application/common/include/app_secrets.h
application/esp32_app/credentials.conf
application/esp32_app/*.local.conf

# Compiled Object Files
*.o
*.obj
*.elf
*.bin
*.hex
*.map
*.lst

# Linker Output
*.ilk
*.exp
*.gch
*.pch
*.lib
*.a
*.la
*.lo

# VS Code Settings (keep shared settings, ignore local)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/ipch

# STM32CubeIDE / Eclipse
.metadata/
.project
.cproject
.settings/
Debug/
Release/

# Keil MDK-ARM
*.uvopt
*.uvoptx
*.uvproj
*.uvprojx
*.bak

# IAR EWARM
*.eww
*.ewd
*.ewp
*.dep
*.dnx

# Python Virtual Environment (pentru TinyML training scripts)
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class

# GitHub Actions self-hosted runner (instalat local, nu face parte din repo)
actions-runner/
_work/

# Zephyr workspace build (pe mașina locală, generat automat)
zephyr/
modules/
bootloader/
tools/
.west/

# Jupyter Notebooks Checkpoints (TinyML dataset analysis)
.ipynb_checkpoints/
*.ipynb

# TensorFlow Model Cache
*.tflite
*.pb
saved_model/
training_checkpoints/

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# Temporary Files
*.tmp
*.temp
*.log
*.swp
*.swo
*~

# Test Results
test_results/
coverage/
e2e-logs/
*.gcov
*.gcda
*.gcno

# Documentation Generated Files (dacă folosim Doxygen)
docs/html/
docs/latex/
docs/xml/

# Node Modules (dacă avem web dashboard pentru visualizare)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dataset Raw (versiuni mari, se ține doar processed)
datasets/raw/*.csv
datasets/raw/*.bin

# Backup Files
*.bak
*.backup
*.old

# Large local/reference documents kept outside normal source review.
# Curated docs may still live under docs/.
*.docx
*.pdf
!docs/**/*.pdf
!docs/**/*.docx

# IDE Specific
*.sublime-project
*.sublime-workspace
.idea/
*.iml

# AI assistant session data
.claude/
.copilot/

# Markdown - keep curated project docs local unless explicitly requested
*.md
!README.md
docs/

# Proiect vechi — doar referință locală
old_project/
