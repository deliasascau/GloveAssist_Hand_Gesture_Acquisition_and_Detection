/*
 * Board overlay for ESP32-WROOM (30-pin DevKit) — GloveAssist ESP32 app
 *
 * UART2:       STM32 inter-MCU communication
 *     GPIO17 TX  (→ STM32 PA10 RX)
 *     GPIO16 RX  (← STM32 PA9  TX)
 * BLE:  Handled by Zephyr BT subsystem
 * WDT:  Task watchdog (wdt0)
 *
 * Flash partition layout for MCUboot OTA (4MB ESP32-WROOM flash):
 *   0x000000 - 0x00FFFF  mcuboot bootloader   (64 KB, read-only)
 *   0x010000 - 0x0FFFFF  image-0 (slot0)      (960 KB, primary running image)
 *   0x100000 - 0x1EFFFF  image-1 (slot1)      (960 KB, OTA update staging area)
 *   0x1F0000 - 0x1FFFFF  image-scratch        (64 KB, MCUboot swap scratch)
 *   0x3F0000 - 0x3FFFFF  storage              (64 KB, NVS / calib data)
 */

/ {
	aliases {
		watchdog0 = &wdt0;
	};
};

&pinctrl {
	uart1_glove: uart1_glove {
		group1 {
			pinmux = <UART1_TX_GPIO17>;
		};

		group2 {
			pinmux = <UART1_RX_GPIO16>;
			bias-pull-up;
		};
	};
};

/* ---- UART2: STM32 inter-MCU communication ---- */
/* GPIO17=TX, GPIO16=RX  (uart2_default, 115200 baud, 8N1 prototype mode) */
&uart2 {
	status = "disabled";
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_glove>;
	pinctrl-names = "default";
};

/* ---- Watchdog ---- */
&wdt0 {
	status = "okay";
};

/*
 * Flash partitions: Using Zephyr default layout (no MCUboot, no custom partitions)
 * ESP32 ROM bootloader + Zephyr will manage:
 *   - 2nd stage bootloader at 0x1000
 *   - Partition table at 0x8000  
 *   - Application at 0x10000
 * Board default includes storage partition already
 */
