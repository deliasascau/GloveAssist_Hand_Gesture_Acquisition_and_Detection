/*
 * Variant overlay for STM32F103C8 "Blue Pill".
 *
 * The common hardware mapping lives in stm32_min_dev.overlay:
 *   - OLED SSD1306 on I2C2 PB10/PB11
 *   - USART1 PA9/PA10 at 115200 baud
 *   - PB4 active buzzer as GPIO
 *   - PB6 TIM4_CH1 motor PWM via ULN2003
 *
 * This variant only reserves the final 2 KB of flash for Zephyr NVS.
 */

&flash0 {
	reg = <0x08000000 0x20000>;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* NVS: 2 pages x 1 KB at the end of 128 KB flash.
		 * Absolute range: 0x0801F800 - 0x0801FFFF.
		 */
		storage_partition: partition@1f800 {
			label = "storage";
			reg = <0x0001f800 0x00000800>;
		};
	};
};
