/*
 * Board overlay for STM32F103C8 "Blue Pill" — GloveAssist STM32 app
 *
 * I2C2:  SSD1306 OLED (PB10 SCL, PB11 SDA)
 * UART1: ESP32 communication (PA9 TX, PA10 RX)
 * ADC:   PA0..PA3 (4 flex sensors, 1kΩ dividers)
 * GPIO:  PB4 active buzzer, PC13 built-in LED (active LOW)
 * PWM:   TIM4_CH1 PB6 motor vibrații via ULN2003
 *        NOTE: PA0 este ADC-only — motorul MUTAT pe PB6 (TIM4_CH1)
 * WDT:   IWDG 2s timeout
 */

/ {
	aliases {
		led0 = &led_builtin;
	};

	leds {
		compatible = "gpio-leds";
		led_builtin: led_0 {
			gpios = <&gpioc 13 GPIO_ACTIVE_LOW>;
			label = "Built-in LED PC13";
		};
	};
};

/* Override flash to 128 KB — most STM32F103C8 chips have 128 KB usable */
&flash0 {
	reg = <0x08000000 0x20000>;
};

/* PB4 is NJTRST after reset on STM32F103. Keep SWD enabled, release JTAG pins. */
&pinctrl {
	swj-cfg = "jtag-disable";
};

/ {
	zephyr,user {
		io-channels = <&adc1 0>, <&adc1 1>, <&adc1 2>, <&adc1 3>;
	};

	aliases {
		watchdog0 = &iwdg;
	};
};

/* ---- ADC (flex sensors PA0..PA3) ---- */
&adc1 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	channel@2 {
		reg = <2>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	channel@3 {
		reg = <3>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

/* ---- I2C2: OLED SSD1306 via PB10(SCL) PB11(SDA) ---- */
&i2c2 {
	status = "okay";
	pinctrl-0 = <&i2c2_scl_pb10 &i2c2_sda_pb11>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_STANDARD>;

	ssd1306: ssd1306@3c {
		compatible = "solomon,ssd1306";
		reg = <0x3c>;
		width = <128>;
		height = <64>;
		segment-offset = <0>;
		page-offset = <0>;
		display-offset = <0>;
		multiplex-ratio = <63>;
		prechargep = <0x22>;
		segment-remap;
		com-invdir;
	};
};

/* PB10/PB11 overlap USART3 pins in the base board DTS. */
&usart3 {
	status = "disabled";
};

/* ---- USART1: ESP32 inter-MCU communication (115200 baud, 8N1 prototype mode) ---- */
/*     PA9 TX → ESP32 GPIO16 RX                                        */
/*     PA10 RX ← ESP32 GPIO17 TX                                       */
&usart1 {
	status = "okay";
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
};

/* ---- Watchdog (IWDG) ---- */
&iwdg {
	status = "okay";
};

/* ---- PWM: TIM4_CH1 PB6 motor ---- */
/* Motor pe TIM4_CH1 (PB6) — PA0 rezervat exclusiv pentru ADC CH0 */
&timers4 {
	status = "okay";

	pwm4: pwm {
		status = "okay";
		pinctrl-0 = <&tim4_ch1_pwm_out_pb6>;
		pinctrl-names = "default";
	};
};

&i2c1 {
	status = "disabled";
};

/ {
	chosen {
		zephyr,display = &ssd1306;
	};

	/* PWM spec node — aliasul din haptic_ui.c cauta motor-pwm */
	pwm_devs {
		compatible = "pwm-leds";
		motor_pwm: motor_pwm {
			/* TIM4_CH1 (PB6), 1ms period, normal polarity */
			pwms = <&pwm4 0 1000000 0>;
		};
	};

	gpio_devs {
		compatible = "gpio-leds";
		buzzer_gpio: buzzer_gpio {
			gpios = <&gpiob 4 GPIO_ACTIVE_HIGH>;
		};
	};

	aliases {
		motor-pwm  = &motor_pwm;
		buzzergpio = &buzzer_gpio;
	};
};
