@startuml
skinparam monochrome true
skinparam shadowing false

actor "User" as USER
node "GloveAssist" as SYSTEM {
  component "STM32F103\nSensor + Processing" as STM
  component "ESP32\nBLE + Storage" as ESP
}
node "iPhone App" as PHONE
cloud "Sniffer Tools\nBLE / UART" as SNIFFER

USER --> PHONE : reads gesture data
STM --> ESP : UART framed data
ESP --> PHONE : BLE notifications
SNIFFER ..> ESP : BLE packet capture
SNIFFER ..> STM : UART frame capture

@enduml
