@startuml
skinparam monochrome true
skinparam shadowing false

participant STM as "STM32"
participant ESP as "ESP32"
participant APP as "iPhone App"

STM -> STM : sample + classify gesture
STM -> ESP : UART GestureEvent(frame, crc)
ESP -> ESP : validate frame
ESP -> APP : BLE notify GestureEvent
APP -> ESP : BLE Ack/Command (optional)
ESP -> STM : UART Config/Control (optional)

@enduml
